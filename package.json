{
  "name": "voicerails",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "platform/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:dashboard": "npm run dev --workspace @voicerails/dashboard",
    "dev:control-plane": "npm run serve --workspace @voicerails/control-plane"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}
