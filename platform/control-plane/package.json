{
  "name": "@voicerails/control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "lint": "echo \"No lint configured for @voicerails/control-plane\"",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy:functions": "echo \"Use root deploy scripts or firebase deploy explicitly\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@voicerails/workflow-engine": "workspace:*",
    "@google-cloud/bigquery": "^7.9.1",
    "@google-cloud/secret-manager": "^5.6.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0",
    "stripe": "^18.6.0",
    "twilio": "^5.10.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  }
}
